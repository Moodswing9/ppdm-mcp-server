{
  "name": "ppdm-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Dell EMC PowerProtect Data Manager and NetWorker — exposes backup infrastructure as Claude Code tools",
  "type": "module",
  "bin": {
    "ppdm-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ppdm",
    "networker",
    "dell-emc",
    "backup",
    "powerprotect",
    "claude-code",
    "data-protection"
  ],
  "author": "Moodswing9",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "dotenv": "^16.0.0",
    "https-proxy-agent": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Moodswing9/ppdm-mcp-server.git"
  },
  "homepage": "https://github.com/Moodswing9/ppdm-mcp-server",
  "engines": {
    "node": ">=18"
  }
